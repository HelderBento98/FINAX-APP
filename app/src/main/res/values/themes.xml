<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FinaxApp" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Launch (splash) theme: brand blue background + centred FINAX mark. -->
    <style name="Theme.FinaxApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.FinaxApp</item>
    </style>
</resources>
