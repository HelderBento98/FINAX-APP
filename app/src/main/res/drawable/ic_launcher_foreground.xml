<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <!-- FINAX mark: an "X" whose rising stroke becomes a growth arrow.
         Content kept inside the adaptive-icon safe zone. -->

    <!-- "\" diagonal (top-left to bottom-right) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="118"
        android:strokeLineCap="butt"
        android:pathData="M250,300 L774,780" />

    <!-- "/" arrow shaft (bottom-left up to the arrowhead) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="118"
        android:strokeLineCap="butt"
        android:pathData="M250,780 L700,400" />

    <!-- arrowhead pointing up-right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M800,300 L786,498 L602,314 Z" />
</vector>
